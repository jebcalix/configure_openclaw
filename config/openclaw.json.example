{
  "agents": {
    "defaults": {
      "workspace": "/home/USER/Proyectos/Repos/jebstudios_ai_assistant",
      "model": { "primary": "ollama/qwen2.5:7b", "fallbacks": [] },
      "models": { "ollama/qwen2.5:7b": {} },
      "thinkingDefault": "off",
      "sandbox": { "mode": "off" },
      "bootstrapMaxChars": 3000,
      "bootstrapTotalMaxChars": 8000,
      "contextInjection": "continuation-skip",
      "startupContext": { "enabled": false }
    }
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "auth": { "mode": "token" }
  },
  "tools": {
    "profile": "minimal",
    "byProvider": {
      "ollama/qwen2.5:7b": {
        "deny": ["group:web", "browser", "group:runtime", "group:fs", "sessions_list"]
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "dmPolicy": "pairing",
      "botToken": {
        "source": "env",
        "provider": "default",
        "id": "TELEGRAM_BOT_TOKEN"
      },
      "groups": { "*": { "requireMention": true } }
    }
  },
  "models": {
    "mode": "replace",
    "providers": {
      "ollama": {
        "baseUrl": "http://127.0.0.1:11434",
        "api": "ollama",
        "apiKey": "OLLAMA_API_KEY",
        "models": [
          {
            "id": "qwen2.5:7b",
            "name": "qwen2.5:7b",
            "contextWindow": 8192,
            "maxTokens": 1024,
            "params": { "num_ctx": 8192 }
          }
        ]
      }
    }
  }
}
